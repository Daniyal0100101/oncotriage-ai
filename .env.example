# OncoTriage AI — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# NVIDIA NIM API key (nvapi-...)
# Get a free key at: https://build.nvidia.com/arc/evo2-40b
# If not set, the app runs in DEMO MODE (simulated outputs only).
NVIDIA_API_KEY=

# Set to "true" ONLY for private NIM deployments that expose the /forward logits endpoint.
# Leave "false" for the hosted NVIDIA NIM API (health.api.nvidia.com).
EVO2_USE_FORWARD_PASS=false
